FROM rust:1.85-bookworm as builder
WORKDIR /usr/src/app
COPY . .
RUN cargo build --release

FROM debian:bookworm-slim
COPY --from=builder /usr/src/app/target/release/nanokvm-control-api /usr/local/bin/
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
# Create stub ISOs for mock boot override tests
RUN mkdir -p /tmp/isos && touch /tmp/isos/disk.iso /tmp/isos/pxe.iso
CMD ["nanokvm-control-api", "serve", "--config", "/etc/nanokvm/config.toml"]
